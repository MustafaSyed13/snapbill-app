# Copy this file to ".env" and fill in the real values. ".env" itself is
# git-ignored — it never gets committed, so secrets never end up on GitHub.

# Supabase → Settings → Database → Connection string → "URI" (use the
# "Transaction pooler" version if offered, it's the one meant for apps like this).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[HOST]:5432/postgres

# Supabase → Settings → API → your Project URL (also shown at the top of Settings → API).
# Used to fetch Supabase's public verification keys (JWKS) to check login tokens.
SUPABASE_URL=https://your-project-ref.supabase.co
